# ReviewOps Agent environment configuration
#
# Copy to .env:   cp .env.example .env
#
# The app is fully runnable WITHOUT any model API key.
# Leave GOOGLE_API_KEY empty and/or keep USE_MOCK_MODEL=true to use the
# deterministic mock agent outputs.

# SQLite database location (relative to project root)
DATABASE_URL=file:./data/reviewops.sqlite

# Google Gemini API key (optional). When set AND USE_MOCK_MODEL=false,
# agents call Gemini via Google ADK / @google/genai.
GOOGLE_API_KEY=

# Force deterministic mock model regardless of GOOGLE_API_KEY.
# true  -> always use mock outputs (default, no network)
# false -> use Gemini if GOOGLE_API_KEY is present, else fall back to mock
USE_MOCK_MODEL=true

# Gemini model id used when a real model is configured.
GEMINI_MODEL=gemini-2.0-flash

# Survey token lifetime in hours (default 7 days).
TOKEN_EXPIRY_HOURS=168
