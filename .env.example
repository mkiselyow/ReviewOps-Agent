# ReviewOps Agent (frontend) environment configuration
#
# Copy to .env:   cp .env.example .env

# SQLite database location (relative to project root)
DATABASE_URL=file:./data/reviewops.sqlite

# Python ADK 2.0 agent service URL (REQUIRED to run the app — the agent brain
# lives there; there is no in-process fallback). The app calls it over REST for
# questionnaire / evidence / review.
#   local dev: run the service (uvicorn app.local_server:app --port 8800)
#   deployed:  the Cloud Run / Agent Runtime URL
AGENT_SERVICE_URL=http://127.0.0.1:8800

# Survey token lifetime in hours (default 7 days).
TOKEN_EXPIRY_HOURS=168

# --- Auth (real-use hardening) ----------------------------------------------
# HMAC secret that signs the session cookie so it cannot be forged. REQUIRED in
# any deployed environment (a weak dev fallback is used if unset, with a warning).
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# Passphrase sign-in for the real manager account (hidden from the demo login
# switcher). Set both to enable it; leave unset to keep demo-only.
MANAGER_PASSPHRASE=
MANAGER_USER_ID=u_real_manager

# Shared secret the frontend sends to the agent service as X-Agent-Key. Must
# MATCH the value set on the agent (agent-service / Cloud Run). Protects the
# public agent from strangers draining the Gemini quota. Leave unset for local dev.
AGENT_SHARED_SECRET=

# Max agent-backed requests (generate/regenerate/review) per manager per hour.
AGENT_RATE_LIMIT_PER_HOUR=30

# Note: the Gemini API key lives in the AGENT SERVICE (agent-service/.env), not
# here — the frontend never calls the model directly.
