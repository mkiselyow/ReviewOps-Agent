# ReviewOps Agent (frontend) environment configuration
#
# Copy to .env:   cp .env.example .env

# SQLite database location (relative to project root)
DATABASE_URL=file:./data/reviewops.sqlite

# Python ADK 2.0 agent service URL (REQUIRED to run the app — the agent brain
# lives there; there is no in-process fallback). The app calls it over REST for
# questionnaire / evidence / review.
#   local dev: run the service (uvicorn app.local_server:app --port 8800)
#   deployed:  the Cloud Run / Agent Runtime URL
AGENT_SERVICE_URL=http://127.0.0.1:8800

# Survey token lifetime in hours (default 7 days).
TOKEN_EXPIRY_HOURS=168

# Note: the Gemini API key lives in the AGENT SERVICE (agent-service/.env), not
# here — the frontend never calls the model directly.
